{
  "request": {
    "method": "POST",
    "url": "/api/v1/text/chat",
    "bodyPatterns": [
      {
        "equalToJson": {
          "messages": [
            {
              "content": [
                {
                  "type": "text",
                  "text": "This is the content of the message"
                }
              ],
              "role": "user"
            }
          ]
        },
        "ignoreExtraElements": true
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "content-type": "application/json"
    },
    "bodyFileName": "responses/single_detection_response.json"
  }
}